# ── Postgres ───────────────────────────────────────────────────────────────
POSTGRES_USER=gateway
POSTGRES_PASSWORD=gateway
POSTGRES_DB=gateway
POSTGRES_PORT=5434
DATABASE_URL=postgres://gateway:gateway@localhost:5434/gateway

# ── Redis ──────────────────────────────────────────────────────────────────
REDIS_PORT=6381
REDIS_URL=redis://localhost:6381

# ── api ────────────────────────────────────────────────────────────────────
API_PORT=5001
API_HOST=0.0.0.0
LOG_LEVEL=info

# Comma-separated list of plugin package names to load on boot.
# First-party plugins ship under @webhook-gateway/plugin-* and are auto-loaded
# from node_modules when listed here.
WEBHOOK_GATEWAY_PLUGINS=@webhook-gateway/plugin-hmac

# ── admin ──────────────────────────────────────────────────────────────────
ADMIN_PORT=5000
NEXT_PUBLIC_API_BASE_URL=http://localhost:5001
ADMIN_BEARER=replace-me-openssl-rand-hex-32

# ── ingress sizing ─────────────────────────────────────────────────────────
INGRESS_MAX_BODY_BYTES=1048576    # 1 MiB
