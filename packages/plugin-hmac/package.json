{
  "name": "@webhook-gateway/plugin-hmac",
  "version": "0.0.0",
  "description": "Generic HMAC SHA-256 signature verifier plugin for webhook-gateway. Catch-all for sources without a dedicated plugin.",
  "license": "MIT",
  "author": "Mateo Kadiu",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateokadiu/webhook-gateway.git",
    "directory": "packages/plugin-hmac"
  },
  "keywords": ["webhook", "hmac", "signature", "webhook-gateway", "plugin"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc --noEmit",
    "lint": "echo 'lint TBD'",
    "test": "vitest run",
    "prepare": "tsc -b"
  },
  "dependencies": {
    "@webhook-gateway/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "@types/node": "^22.10.0",
    "vitest": "^2.1.8"
  },
  "publishConfig": { "access": "public" }
}
