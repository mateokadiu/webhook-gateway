{
  "name": "webhook-gateway",
  "private": true,
  "version": "1.0.0",
  "description": "Self-hosted webhook reliability gateway: verify, persist, fan out, retry, replay.",
  "license": "MIT",
  "author": "Mateo Kadiu",
  "repository": {
    "type": "git",
    "url": "https://github.com/mateokadiu/webhook-gateway.git"
  },
  "homepage": "https://github.com/mateokadiu/webhook-gateway#readme",
  "bugs": "https://github.com/mateokadiu/webhook-gateway/issues",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "test": "turbo run test",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "compose:up": "docker compose --env-file .env up -d",
    "compose:down": "docker compose down",
    "db:migrate": "pnpm --filter @webhook-gateway/api db:migrate",
    "db:generate": "pnpm --filter @webhook-gateway/api db:generate"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.2"
  }
}
